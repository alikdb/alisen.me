{
  "rewrites": [
    {
      "source": "/api/spotify-auth/:path*",
      "destination": "https://accounts.spotify.com/:path*"
    },
    {
      "source": "/api/spotify/:path*",
      "destination": "https://api.spotify.com/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
